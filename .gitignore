.venv
.env
.mypy_cache
.cursor
# Build outputs: ignore the whole build/ tree except the shipped Nuitka onefile exe.
# Order matters for git: un-ignore the directory, then re-ignore its contents, then
# un-ignore the single tracked binary (so `git add build/nuitka/pdfDiffChecker.exe` works).
/build/**
!/build/nuitka/
/build/nuitka/**
!/build/nuitka/pdfDiffChecker.exe
dist
temp
tmp_m2_*_verify/
# Not published on public GitHub (keep locally)
tests/
docs/*.drawio
docs/tasks/M*PLAN.md
views/*.bak
__pycache__/
.python-version
memo.py
.windsurfrules
pdfium.dll
sample*
logs/debug.log

